rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // This checks if the user is in the 'admins' collection.
    // Pro tip: Add your UID to /admins/YOUR_UID in Firestore to gain access.
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Profiles are publicly readable for social features
      allow read: if true;
      
      // Only the owner can edit their own profile
      allow write: if isOwner(userId) 
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['joinedAt', 'email']));
      
      allow create: if isOwner(userId);
    }

    // --- SESSIONS (Anti-Cheat) ---
    match /sessions/{sessionId} {
      // Only the user can create/read their own session start time
      allow read, write: if isOwner(request.auth.uid) && sessionId.endsWith(request.auth.uid);
    }

    // --- LEADERBOARD COLLECTION ---
    match /leaderboard/{docId} {
      allow read: if true;
      
      function isValidSubmission() {
        let session = get(/databases/$(database)/documents/sessions/$(docId)).data;
        let playDuration = request.time - session.startTime;
        return isAuthenticated() 
          && request.resource.data.uid == request.auth.uid
          && docId.endsWith(request.auth.uid)
          && request.resource.data.score is int
          && request.resource.data.score > 0
          && request.resource.data.score < 1000000
          && playDuration >= duration.value(5, 's'); // Harus main minimal 5 detik
      }

      allow create: if isValidSubmission();
      allow update: if isValidSubmission() && request.resource.data.score > resource.data.score;

      allow delete: if isAdmin();
    }

    // --- ACTIVITY / SOCIAL FEED ---
    match /activity/{docId} {
      allow read: if true;
      
      // User can only log their own activity
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
      
      allow delete: if isOwner(resource.data.userId) || isAdmin();
      allow update: if false; // Activities shouldn't be edited
    }

    // --- ANALYTICS EVENTS ---
    match /analytics_events/{docId} {
      // Only admins can see overall analytics
      allow read: if isAdmin();
      
      // Anyone (even guests) can push usage analytics
      allow create: if true; 
      
      allow update, delete: if false;
    }

    // --- ADMINS COLLECTION ---
    match /admins/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false; // Admins are managed via Firebase Console for security
    }

    // --- DEFAULT RULE ---
    match /{path=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
